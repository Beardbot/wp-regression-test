# Copy this file to .env and fill in your values.
# .env should never be committed to version control.

# SMTP credentials for email notifications
# Use the outbound SMTP hostname provided by your email host (not a URL).
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=alerts@yourdomain.com
SMTP_TO=you@yourdomain.com

# Secret token shared between this server and the WordPress plugin (Option 2 only).
# Generate any long random string, e.g.: openssl rand -hex 32
WP_REGRESSION_SECRET=replace-with-a-long-random-secret
