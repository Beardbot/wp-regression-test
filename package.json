{
  "name": "wp-regression-tester",
  "version": "1.0.0",
  "description": "Automated regression testing for WordPress sites after updates",
  "main": "index.js",
  "bin": {
    "baseline": "./bin/baseline.js",
    "test": "./bin/test.js"
  },
  "scripts": {
    "postinstall": "npx playwright install chromium",
